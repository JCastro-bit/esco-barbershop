---
import Layout from '../layouts/Layout.astro';

const whatsappUrl = "https://wa.me/523333970077?text=Qu%C3%A9%20onda%2C%20quiero%20agendar%20un%20corte%20en%20Esco";

const services = [
	{ name: "Low Fade", icon: "◣" },
	{ name: "Mid Fade", icon: "◧" },
	{ name: "High Fade", icon: "◥" },
	{ name: "Diseño de Líneas", icon: "⟋" },
	{ name: "Barba Sculpting", icon: "◈" },
	{ name: "Color / Decoloración", icon: "◉" },
	{ name: "Corte Clásico", icon: "✂" },
	{ name: "Cejas", icon: "⟁" },
];

const testimonials = [
	{ text: "Los mejores fades de GDL, sin discusión. Siempre salgo perfecto.", author: "Kevin R." },
	{ text: "Encontré mi barbería. El ambiente está increíble y el corte siempre on point.", author: "Bryan M." },
	{ text: "5 estrellas merecidas. Estos batos saben lo que hacen.", author: "Luis A." },
];

const vibeImages = [
	{ src: "https://images.unsplash.com/photo-1605497788044-5a32c7078486?w=600&h=750&fit=crop", alt: "Barbería moderna con luces neón" },
	{ src: "https://images.unsplash.com/photo-1622286342621-4bd786c2447c?w=600&h=750&fit=crop", alt: "Fade perfecto" },
	{ src: "https://images.unsplash.com/photo-1493256338651-d82f7acb2b38?w=600&h=750&fit=crop", alt: "Silla de barbero contemporánea" },
	{ src: "https://images.unsplash.com/photo-1493256338651-d82f7acb2b38?w=600&h=750&fit=crop", alt: "Herramientas de barbería" },
];

const igImages = [
	"https://images.unsplash.com/photo-1605497788044-5a32c7078486?w=400&h=400&fit=crop",
	"https://images.unsplash.com/photo-1622286342621-4bd786c2447c?w=400&h=400&fit=crop",
	"https://images.unsplash.com/photo-1493256338651-d82f7acb2b38?w=400&h=400&fit=crop",
	"https://images.unsplash.com/photo-1493256338651-d82f7acb2b38?w=400&h=400&fit=crop",
];
---

<Layout>
	<!-- ═══════ HERO ═══════ -->
	<section class="hero-gradient relative min-h-screen flex flex-col items-center justify-center overflow-hidden px-4">
		<!-- Geometric decorations -->
		<div class="geo-line geo-line-h absolute top-[15%] left-0"></div>
		<div class="geo-line geo-line-h absolute bottom-[20%] left-0"></div>
		<div class="geo-line geo-line-v absolute top-0 left-[10%] hidden lg:block"></div>
		<div class="geo-line geo-line-v absolute top-0 right-[10%] hidden lg:block"></div>

		<!-- Corner accents -->
		<div class="absolute top-6 left-6 w-12 h-12 border-t border-l border-[var(--color-neon)] opacity-30"></div>
		<div class="absolute top-6 right-6 w-12 h-12 border-t border-r border-[var(--color-neon)] opacity-30"></div>
		<div class="absolute bottom-6 left-6 w-12 h-12 border-b border-l border-[var(--color-neon)] opacity-30"></div>
		<div class="absolute bottom-6 right-6 w-12 h-12 border-b border-r border-[var(--color-neon)] opacity-30"></div>

		<!-- Badge -->
		<div class="reveal slide-up mb-6 md:mb-8 inline-flex items-center gap-2 border border-[var(--color-neon)] rounded-full px-5 py-2 text-sm tracking-widest uppercase" style="animation-delay: 0.1s;">
			<span class="text-[var(--color-neon)]">★</span>
			<span class="text-white/90 font-medium">5.0 · Rating perfecto · 25 reseñas</span>
		</div>

		<!-- ESCO massive -->
		<h1 class="glitch-text font-[var(--font-display)] text-[clamp(6rem,22vw,16rem)] leading-[0.85] tracking-tight text-white text-center select-none" data-text="ESCO">
			ESCO
		</h1>

		<!-- BARBERSHOP -->
		<p class="font-[var(--font-display)] text-[clamp(1.2rem,4vw,2.8rem)] tracking-[0.35em] text-white/60 mt-2 md:mt-3 text-center uppercase">
			Barbershop
		</p>

		<!-- Subtitle -->
		<p class="reveal slide-up text-white/50 text-sm md:text-base tracking-[0.2em] uppercase mt-4 md:mt-6 text-center" style="animation-delay: 0.3s;">
			Tu estilo, tu regla · Guadalajara
		</p>

		<!-- CTA -->
		<a
			href={whatsappUrl}
			target="_blank"
			rel="noopener"
			class="reveal scale-in mt-10 md:mt-14 inline-block bg-[var(--color-neon)] text-black font-bold text-sm md:text-base tracking-[0.15em] uppercase px-10 py-4 hover:bg-white transition-colors duration-300 no-underline"
			style="animation: neon-btn-pulse 2.5s ease-in-out infinite, scale-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;"
		>
			Agenda tu corte
		</a>

		<!-- Scroll indicator -->
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40">
			<span class="text-[10px] tracking-[0.3em] uppercase">Scroll</span>
			<div class="w-px h-8 bg-gradient-to-b from-white to-transparent"></div>
		</div>
	</section>

	<!-- ═══════ SERVICIOS ═══════ -->
	<section class="relative py-24 md:py-32 px-4 overflow-hidden" id="servicios">
		<!-- Section BG accent -->
		<div class="absolute inset-0 bg-gradient-to-b from-transparent via-[rgba(57,255,20,0.015)] to-transparent pointer-events-none"></div>

		<div class="max-w-6xl mx-auto relative">
			<!-- Section label -->
			<div class="reveal slide-up flex items-center gap-4 mb-4">
				<div class="w-8 h-px bg-[var(--color-neon)]"></div>
				<span class="text-[var(--color-neon)] text-xs tracking-[0.3em] uppercase font-semibold">Lo que hacemos</span>
			</div>

			<h2 class="reveal slide-up font-[var(--font-display)] text-[clamp(2.5rem,7vw,5rem)] leading-[0.95] text-white mb-14" style="animation-delay: 0.1s;">
				SERVICIOS
			</h2>

			<div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
				{services.map((s, i) => (
					<div
						class="reveal scale-in service-card neon-border bg-[var(--color-dark-card)] p-5 md:p-7 cursor-default group"
						style={`animation-delay: ${0.1 + i * 0.07}s;`}
					>
						<span class="service-icon block text-2xl md:text-3xl text-white/40 mb-3 md:mb-4">{s.icon}</span>
						<span class="text-white text-sm md:text-base font-semibold tracking-wide">{s.name}</span>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ═══════ EL VIBE ═══════ -->
	<section class="relative py-24 md:py-32 px-4 overflow-hidden" id="vibe">
		<div class="max-w-7xl mx-auto">
			<!-- Section label -->
			<div class="reveal slide-up flex items-center gap-4 mb-4">
				<div class="w-8 h-px bg-[var(--color-neon-cyan)]"></div>
				<span class="text-[var(--color-neon-cyan)] text-xs tracking-[0.3em] uppercase font-semibold">La experiencia</span>
			</div>

			<div class="flex flex-col lg:flex-row lg:items-end lg:justify-between mb-12 md:mb-16 gap-6">
				<h2 class="reveal slide-up font-[var(--font-display)] text-[clamp(2.5rem,7vw,5rem)] leading-[0.95] text-white" style="animation-delay: 0.1s;">
					EL VIBE
				</h2>
				<p class="reveal slide-left text-white/50 text-base md:text-lg max-w-md leading-relaxed" style="animation-delay: 0.2s;">
					Más que una barbería.<br/>
					<span class="text-white/80 font-medium">Un lugar donde tu estilo cobra vida.</span>
