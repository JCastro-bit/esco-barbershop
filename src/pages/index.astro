			</div>

			<!-- Photo grid — asymmetric, overlapping -->
			<div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
				<div class="reveal slide-up col-span-2 md:row-span-2 relative overflow-hidden aspect-[4/5] md:aspect-auto" style="animation-delay: 0.15s;">
					<img
